{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": [
        "./components/*"
      ],
      "@context/*": [
        "./context/*"
      ],
      "@lib/*": [
        "./lib/*"
      ],
      "@services/*": [
        "./services/*"
      ],
      "@assets/*": [
        "./assets/*"
      ],
      "@types/*": [
        "./types/*"
      ],
      "@mocks/*": [
        "./__mocks__/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}