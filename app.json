{
  "expo": {
    "name": "fdm_flatfinder",
    "slug": "fdm_flatfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.svg",
    "scheme": "fdmflatfinder",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.fdm.flatfinder",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.svg",
        "backgroundColor": "#1b1b1b"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.svg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1b1b1b",
          "dark": {
            "backgroundColor": "#1b1b1b"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}